# Versão das imagens do backend publicadas no GitHub Container Registry.
# Esta tag é usada pela Control API, Dispatch Worker e PostgreSQL customizado.
BACKEND_IMAGE_TAG=v1.0.0

# Versão da imagem do frontend publicada no GitHub Container Registry.
# Esta tag é usada pelo Email Marketing Web.
FRONTEND_IMAGE_TAG=v1.0.0

# Variáveis de ambiente comuns a todos os serviços.
NODE_ENV=test
LOG_LEVEL=info

# Portas publicadas localmente na máquina host.
WEB_PUBLISHED_PORT=3001
CONTROL_API_PUBLISHED_PORT=3333
POSTGRES_PUBLISHED_PORT=5433
REDIS_PUBLISHED_PORT=6380
SMTP_PUBLISHED_PORT=1025
MAILPIT_UI_PUBLISHED_PORT=8025

# PostgreSQL.
POSTGRES_DB=email_marketing
POSTGRES_USER=email_marketing
POSTGRES_PASSWORD=email_marketing
POSTGRES_HOST=postgres
POSTGRES_PORT=5432  # Porta interna

# Redis.
REDIS_HOST=redis
REDIS_PORT=6379     # Porta interna

# Mailpit / SMTP.
SMTP_HOST=mailpit
SMTP_PORT=1025      # Porta interna

# Chave de criptografia usada para proteger dados sensíveis relacionados ao SMTP Sender. 
SMTP_SENDER_ENCRYPTION_KEY=encryption_key_1234567890

# Control API.
# Email Marketing Web.
# Variáveis privadas de runtime usadas pelo servidor/proxy do frontend.
# Não use NEXT_PUBLIC_* aqui.
#
# O navegador chama rotas relativas do próprio frontend.
# O servidor do frontend encaminha essas requisições para a Control API
# pela rede interna do Docker.
# Porta interna usada pela API dentro da rede Docker.
API_PORT=3333
# Porta publicada na máquina host para acessar a Control API por localhost.
API_BASE_URL=http://control-api:3333
OPENAPI_SCHEMA_URL=http://control-api:3333/documentation/json

CORS_ORIGINS=http://localhost:3001

# API externa opcional de CNPJ usada pelo backend,
# quando estiver disponível na máquina host.
CNPJ_API_BASE_URL=http://host.docker.internal:3000
